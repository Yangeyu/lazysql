{
  "name": "@vascent/lazysql",
  "version": "0.1.16",
  "description": "A lazygit-style TUI database manager.",
  "keywords": [
    "tui",
    "database",
    "sql",
    "cli",
    "postgres",
    "mysql",
    "mariadb",
    "sqlite",
    "mongodb",
    "redis",
    "lazygit",
    "terminal",
    "nl2sql"
  ],
  "author": "yangwb",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Yangeyu/lazysql.git"
  },
  "homepage": "https://github.com/Yangeyu/lazysql#readme",
  "bugs": {
    "url": "https://github.com/Yangeyu/lazysql/issues"
  },
  "type": "module",
  "engines": {
    "bun": ">=1.2.16"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "lazysql": "src/main.tsx"
  },
  "scripts": {
    "start": "bun run src/main.tsx",
    "dev": "bun run src/main.tsx",
    "build": "bun build src/main.tsx --compile --outfile dist/lazysql",
    "build:npm": "bun scripts/build-npm.ts",
    "seed": "bun run scripts/seed.ts",
    "typecheck": "tsc --noEmit",
    "changelog": "git-cliff -o CHANGELOG.md",
    "release": "bun scripts/release.ts",
    "test": "bun test",
    "commitlint": "commitlint --edit",
    "prepare": "git config core.hooksPath .githooks"
  },
  "overrides": {
    "bson": "7.2.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@opentui/core": "^0.4.3",
    "@opentui/react": "^0.4.3",
    "mongodb": "^7.3.0",
    "mysql2": "^3.22.5",
    "react": "^19.2.0",
    "string-width": "^8.2.1",
    "yaml": "^2.9.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@types/bun": "^1.3.14",
    "@types/react": "^19",
    "git-cliff": "^2.13.1",
    "typescript": "^5.7.2"
  }
}
