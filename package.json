{
  "name": "lazysql",
  "version": "0.0.0",
  "description": "A lazygit-style TUI database manager.",
  "type": "module",
  "private": true,
  "bin": {
    "lazysql": "src/main.tsx"
  },
  "scripts": {
    "start": "bun run src/main.tsx",
    "dev": "bun run src/main.tsx",
    "seed": "bun run scripts/seed.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "ink": "^5.1.0",
    "mysql2": "^3.22.5",
    "pg": "^8.22.0",
    "react": "^18.3.1",
    "yaml": "^2.9.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.12",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5.7.2"
  }
}
